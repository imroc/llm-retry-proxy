<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>llm-retry-proxy</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/llm-retry-proxy</string>
        <string>--config</string>
        <string>/etc/llm-retry-proxy/config.toml</string>
        <string>--log-level</string>
        <string>info</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
</dict>
</plist>
